<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{{ title }}</title>
  {{#if googleFont}}
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family={{ fontFamily }}:wght@400;600;700&display=swap" rel="stylesheet" />
  {{/if}}
  <style>
    :root {
      --bg:      {{ theme.background }};
      --surface: {{ theme.surface }};
      --accent:  {{ theme.accent }};
      --text:    {{ theme.text }};
      --radius:  {{ theme.radius }};
      --font:    {{ fontStack }};
      {{#if theme.border}}--border: {{ theme.border }};{{/if}}
    }
    {{{ css }}}
  </style>
</head>
<body>
  <main>
    <header class="profile">
      {{#if avatar}}
      <img class="avatar" src="{{ avatar }}" alt="{{ title }}" />
      {{/if}}
      <h1>{{ title }}</h1>
      {{#if bio}}
      <p class="bio">{{ bio }}</p>
      {{/if}}
    </header>

    {{#each rows}}
    <div class="page-row" style="max-width: {{columnWidth}}">
      {{#each sections}}
      <section class="site-section site-section--{{type}}" id="{{id}}" style="flex: {{width}}">
        {{#if title}}<h2 class="section-heading">{{title}}</h2>{{/if}}
        {{> (lookup . 'type') this}}
      </section>
      {{/each}}
    </div>
    {{/each}}
  </main>
</body>
</html>
